{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "funfsterne",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.funfsterne.mobile"
    },
    "android": {
      "package": "com.funfsterne.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0A",
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0A0A0A",
            "image": "./assets/splash-icon.png"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#C9A84C"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "039e2e3e-b52e-477a-a8be-73426a2332eb"
      },
      "apiBaseUrl": "https://funfsterne-admin.onrender.com"
    },
    "owner": "omran22"
  }
}
