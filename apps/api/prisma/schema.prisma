generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductCategory {
  HAIR
  SKIN_CARE
  BEARD
  TOOLS
  OTHER
}

enum DiscountCodeType {
  PERCENTAGE
  FIXED
}

enum Platform {
  IOS
  ANDROID
}

model Branch {
  id          String                    @id @default(cuid())
  name        String
  address     String
  city        String
  postalCode  String
  phone       String?
  isActive    Boolean                   @default(true)
  products    ProductBranchAvailability[]
  users       User[]                      @relation("PreferredBranch")
  discountCodes DiscountCode[]            @relation("DiscountCodeScopeBranch")
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@index([isActive])
}

model Product {
  id            String                    @id @default(cuid())
  name          String
  description   String?
  category      ProductCategory
  basePrice     Decimal                   @db.Decimal(10, 2)
  images        String[]                  @default([])
  isActive      Boolean                   @default(true)
  availabilities ProductBranchAvailability[]
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@index([category])
  @@index([isActive])
}

model ProductBranchAvailability {
  id            String   @id @default(cuid())
  productId     String
  branchId      String
  inStock       Boolean  @default(true)
  priceOverride Decimal? @db.Decimal(10, 2)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId])
  @@index([productId])
  @@index([branchId])
  @@index([inStock])
}

model DiscountCode {
  id                String                   @id @default(cuid())
  code              String                   @unique
  type              DiscountCodeType
  value             Decimal                  @db.Decimal(10, 2)
  expiresAt         DateTime?
  maxRedemptions    Int?
  currentRedemptions Int                     @default(0)
  isActive          Boolean                  @default(true)
  scopeBranchId     String?
  scopeBranch       Branch?                  @relation("DiscountCodeScopeBranch", fields: [scopeBranchId], references: [id], onDelete: SetNull)
  notifications     Notification[]
  redemptions       DiscountCodeRedemption[]

  @@index([code])
  @@index([isActive])
  @@index([scopeBranchId])
}

model User {
  id                String     @id @default(cuid())
  phone             String?    @unique
  email             String?    @unique
  name              String?
  preferredBranchId String?
  preferredBranch   Branch?    @relation("PreferredBranch", fields: [preferredBranchId], references: [id], onDelete: SetNull)
  pushTokens        PushToken[]
  redemptions       DiscountCodeRedemption[]
  createdAt         DateTime   @default(now())

  @@index([preferredBranchId])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  Platform
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([platform])
}

model MagicLink {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

model DiscountCodeRedemption {
  id             String       @id @default(cuid())
  userId         String
  discountCodeId String
  redeemedAt     DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  discountCode   DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)

  @@unique([userId, discountCodeId])
  @@index([userId])
  @@index([discountCodeId])
}

model Notification {
  id             String        @id @default(cuid())
  title          String
  body           String
  discountCodeId String?
  discountCode   DiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)
  sentAt         DateTime      @default(now())
  sentToCount    Int           @default(0)

  @@index([discountCodeId])
  @@index([sentAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
